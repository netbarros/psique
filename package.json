{
  "name": "psique",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib scripts test e2e proxy.ts playwright.config.ts vitest*.config.ts",
    "typecheck": "tsc --noEmit",
    "contract:manifest:enrich": "npm exec --yes node scripts/enrich-canonical-manifest-v4.mjs",
    "contract:manifest:check": "npm exec --yes node scripts/check-canonical-manifest.mjs",
    "contract:catalog:generate": "npm exec --yes node scripts/generate-screen-catalog.mjs",
    "contract:non-screen:check": "npm exec --yes node scripts/check-non-screen-routes.mjs",
    "backend:surface:write": "npm exec --yes node scripts/check-backend-api-surface.mjs -- --write",
    "backend:surface:check": "npm exec --yes node scripts/check-backend-api-surface.mjs -- --check",
    "docs:watch:snapshot": "npm exec --yes node scripts/track-docs-updates.mjs -- --write",
    "docs:watch:check": "npm exec --yes node scripts/track-docs-updates.mjs -- --check",
    "docs:sync:check": "npm exec --yes node scripts/sync-stitch-mirror.mjs -- --check",
    "docs:sync:write": "npm exec --yes node scripts/sync-stitch-mirror.mjs -- --write",
    "baseline:freeze": "npm exec --yes node scripts/mf21-freeze-baseline.mjs",
    "lint:colors:baseline": "npm exec --yes node scripts/check-no-hardcoded-colors.mjs -- --write-baseline",
    "lint:colors": "npm exec --yes node scripts/check-no-hardcoded-colors.mjs -- --check",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:api": "vitest run --config vitest.api.config.ts",
    "test:api:coverage": "vitest run --config vitest.api.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --grep @visual",
    "supabase:preflight": "node scripts/supabase-preflight.mjs",
    "supabase:preflight:static": "node scripts/supabase-preflight.mjs --skip-runtime",
    "supabase:preflight:runtime": "node scripts/supabase-preflight.mjs",
    "supabase:preflight:write": "node scripts/supabase-preflight.mjs --write-report",
    "backend:audit": "npm exec --yes node scripts/backend-audit-orchestrator.mjs",
    "backend:audit:write": "npm exec --yes node scripts/backend-audit-orchestrator.mjs -- --write-report",
    "verify:backend": "npm run lint && npm run typecheck && npm run contract:non-screen:check && npm run backend:surface:check && npm run backend:audit && npm run test:api && npm run supabase:preflight:static",
    "verify:backend:runtime": "npm run lint && npm run typecheck && npm run contract:non-screen:check && npm run backend:surface:check && npm run backend:audit && npm run test:api && npm run supabase:preflight:runtime",
    "verify": "npm run lint && npm run typecheck && npm run contract:manifest:check && npm run contract:non-screen:check && npm run docs:sync:check && npm run lint:colors && npm run backend:audit && npm run build && npm run test:unit && npm run test:api",
    "verify:ci": "npm run verify && npm run test:e2e && npm run test:visual"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/nextjs": "^10.42.0",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.576.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.25.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
